model profile_app_album {
  id                     BigInt                   @id @default(autoincrement())
  name                   String                   @db.VarChar(100)
  theme                  String?                  @db.VarChar(50)
  year                   Int?
  is_shown               Boolean
  is_default             Boolean
  created_at             DateTime                 @db.Timestamptz(6)
  profile_id             BigInt
  profile_app_profile    profile_app_profile      @relation(fields: [profile_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "profile_app_album_profile_id_7414a460_fk_profile_app_profile_id")
  profile_app_albumimage profile_app_albumimage[]

  @@index([profile_id], map: "profile_app_album_profile_id_7414a460")
}

model profile_app_albumimage {
  id                BigInt            @id @default(autoincrement())
  image             String            @db.VarChar(100)
  is_shown          Boolean
  created_at        DateTime          @db.Timestamptz(6)
  album_id          BigInt
  profile_app_album profile_app_album @relation(fields: [album_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "profile_app_albumima_album_id_9736c867_fk_profile_a")

  @@index([album_id], map: "profile_app_albumimage_album_id_9736c867")
}
